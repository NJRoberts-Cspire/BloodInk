<Project Sdk="Godot.NET.Sdk/4.6.1">
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <EnableDynamicLoading>true</EnableDynamicLoading>
    <RootNamespace>BloodInk</RootNamespace>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>
  <!-- Exclude addon C# files that have incompatible code / their own project structure -->
  <ItemGroup>
    <Compile Remove="addons/phantom_camera/**/*.cs" />
    <Compile Remove="addons/gdUnit4/**/*.cs" />
    <Compile Remove="addons/event_audio/**/*.cs" />
  </ItemGroup>
</Project>
