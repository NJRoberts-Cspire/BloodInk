; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited via text if you know what you're doing.

config_version=5

[application]

config/name="BloodInk"
config/description="2D Top-Down Action RPG"
run/main_scene="res://Scenes/UI/MainMenu.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://Scripts/Core/GameManager.cs"
NoisePropagator="*res://Scripts/Stealth/NoisePropagator.cs"
InteractionManager="*res://Scripts/Interaction/InteractionManager.cs"
DialogueManager="*res://Scripts/Dialogue/DialogueManager.cs"
AudioManager="*res://Scripts/Audio/AudioManager.cs"
FadeLayer="*res://Scenes/UI/FadeLayer.tscn"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[dotnet]

project/assembly_name="BloodInk"

